  80:Core/Src/tmc5160.c **** 
  81:Core/Src/tmc5160.c ****   /* CHOPCONF: TOFF=3, HSTRT=4, HEND=1, TBL=2 - the datasheet's baseline
  82:Core/Src/tmc5160.c ****    * SpreadCycle configuration. TOFF != 0 is what actually enables the
  83:Core/Src/tmc5160.c ****    * chopper; with TOFF=0 the motor stays unpowered. */
  84:Core/Src/tmc5160.c ****   tmc5160_write(TMC5160_REG_CHOPCONF, 0x000100C3u);
  85:Core/Src/tmc5160.c **** 
  86:Core/Src/tmc5160.c ****   /* Motor current. GLOBALSCALER scales the full-scale current set by the
  87:Core/Src/tmc5160.c ****    * sense resistors (0 = 256/256 = full scale). 128 = half scale is a
  88:Core/Src/tmc5160.c ****    * gentle default for bring-up -- ADJUST for your R_sense and motor:
  89:Core/Src/tmc5160.c ****    *   I_rms = GLOBALSCALER/256 * (IRUN+1)/32 * V_fs/R_sense * 1/sqrt(2)
  90:Core/Src/tmc5160.c ****    * with V_fs = 0.325 V. */
  91:Core/Src/tmc5160.c ****   tmc5160_write(TMC5160_REG_GLOBALSCALER, 128u);
  92:Core/Src/tmc5160.c **** 
  93:Core/Src/tmc5160.c ****   /* IHOLD_IRUN: IRUN=16/31 run current, IHOLD=8/31 standstill current,
  94:Core/Src/tmc5160.c ****    * IHOLDDELAY=6 (smooth ramp-down to hold current). */
  95:Core/Src/tmc5160.c ****   tmc5160_write(TMC5160_REG_IHOLD_IRUN, (6u << 16) | (16u << 8) | 8u);
  96:Core/Src/tmc5160.c **** 
  97:Core/Src/tmc5160.c ****   /* TPOWERDOWN=10: ~0.2 s from standstill to hold-current reduction */
  98:Core/Src/tmc5160.c ****   tmc5160_write(TMC5160_REG_TPOWERDOWN, 10u);
  99:Core/Src/tmc5160.c **** 
 100:Core/Src/tmc5160.c ****   /* Ramp generator: a modest trapezoid/S-ramp for a first spin.
 101:Core/Src/tmc5160.c ****    * Velocity unit is usteps/t, t = 2^24 / f_clk (~1.4 s at 12 MHz internal
 102:Core/Src/tmc5160.c ****    * clock), so VMAX=200000 is roughly 2.8 rev/s at 256 usteps. */
 103:Core/Src/tmc5160.c ****   tmc5160_write(TMC5160_REG_VSTART, 0u);
 104:Core/Src/tmc5160.c ****   tmc5160_write(TMC5160_REG_A1,     1000u);
 105:Core/Src/tmc5160.c ****   tmc5160_write(TMC5160_REG_V1,     50000u);
 106:Core/Src/tmc5160.c ****   tmc5160_write(TMC5160_REG_AMAX,   5000u);
 107:Core/Src/tmc5160.c ****   tmc5160_write(TMC5160_REG_VMAX,   200000u);
 108:Core/Src/tmc5160.c ****   tmc5160_write(TMC5160_REG_DMAX,   7000u);
 109:Core/Src/tmc5160.c ****   tmc5160_write(TMC5160_REG_D1,     1400u);
