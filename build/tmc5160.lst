   1:Core/Src/tmc5160.c **** /**
   2:Core/Src/tmc5160.c ****   ******************************************************************************
   3:Core/Src/tmc5160.c ****   * @file    tmc5160.c
   4:Core/Src/tmc5160.c ****   * @brief   Minimal TMC5160 SPI driver.
   5:Core/Src/tmc5160.c ****   *
   6:Core/Src/tmc5160.c ****   * The TMC5160 uses 40-bit SPI datagrams (SPI mode 3, MSB first):
   7:Core/Src/tmc5160.c ****   *   byte 0      : register address (bit 7 set = write)
   8:Core/Src/tmc5160.c ****   *   bytes 1..4  : 32-bit data, MSB first
   9:Core/Src/tmc5160.c ****   * Every transfer also returns 40 bits: an 8-bit SPI status followed by the
  10:Core/Src/tmc5160.c ****   * 32-bit data requested by the *previous* datagram, so a register read takes
  11:Core/Src/tmc5160.c ****   * two transfers.
  12:Core/Src/tmc5160.c ****   ******************************************************************************
  13:Core/Src/tmc5160.c ****   */
  14:Core/Src/tmc5160.c **** 
