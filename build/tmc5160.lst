  74:Core/Src/tmc5160.c ****   /* Clear reset/error flags (GSTAT bits are cleared by writing 1) */
  75:Core/Src/tmc5160.c ****   tmc5160_write(TMC5160_REG_GSTAT, 0x07u);
  76:Core/Src/tmc5160.c **** 
