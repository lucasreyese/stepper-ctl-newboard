 236:Core/Src/system_stm32g4xx.c ****   {
 237:Core/Src/system_stm32g4xx.c ****     case 0x04:  /* HSI used as system clock source */
 238:Core/Src/system_stm32g4xx.c ****       SystemCoreClock = HSI_VALUE;
 239:Core/Src/system_stm32g4xx.c ****       break;
 240:Core/Src/system_stm32g4xx.c **** 
