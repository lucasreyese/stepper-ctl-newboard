 194:Core/Src/system_stm32g4xx.c **** /**
 195:Core/Src/system_stm32g4xx.c ****   * @brief  Update SystemCoreClock variable according to Clock Register Values.
 196:Core/Src/system_stm32g4xx.c ****   *         The SystemCoreClock variable contains the core clock (HCLK), it can
 197:Core/Src/system_stm32g4xx.c ****   *         be used by the user application to setup the SysTick timer or configure
 198:Core/Src/system_stm32g4xx.c ****   *         other parameters.
 199:Core/Src/system_stm32g4xx.c ****   *
 200:Core/Src/system_stm32g4xx.c ****   * @note   Each time the core clock (HCLK) changes, this function must be called
 201:Core/Src/system_stm32g4xx.c ****   *         to update SystemCoreClock variable value. Otherwise, any configuration
 202:Core/Src/system_stm32g4xx.c ****   *         based on this variable will be incorrect.
 203:Core/Src/system_stm32g4xx.c ****   *
 204:Core/Src/system_stm32g4xx.c ****   * @note   - The system frequency computed by this function is not the real
 205:Core/Src/system_stm32g4xx.c ****   *           frequency in the chip. It is calculated based on the predefined
 206:Core/Src/system_stm32g4xx.c ****   *           constant and the selected clock source:
 207:Core/Src/system_stm32g4xx.c ****   *
 208:Core/Src/system_stm32g4xx.c ****   *           - If SYSCLK source is HSI, SystemCoreClock will contain the HSI_VALUE(**)
 209:Core/Src/system_stm32g4xx.c ****   *
 210:Core/Src/system_stm32g4xx.c ****   *           - If SYSCLK source is HSE, SystemCoreClock will contain the HSE_VALUE(***)
 211:Core/Src/system_stm32g4xx.c ****   *
 212:Core/Src/system_stm32g4xx.c ****   *           - If SYSCLK source is PLL, SystemCoreClock will contain the HSE_VALUE(***)
 213:Core/Src/system_stm32g4xx.c ****   *             or HSI_VALUE(*) multiplied/divided by the PLL factors.
 214:Core/Src/system_stm32g4xx.c ****   *
 215:Core/Src/system_stm32g4xx.c ****   *         (**) HSI_VALUE is a constant defined in stm32g4xx_hal.h file (default value
 216:Core/Src/system_stm32g4xx.c ****   *              16 MHz) but the real value may vary depending on the variations
 217:Core/Src/system_stm32g4xx.c ****   *              in voltage and temperature.
 218:Core/Src/system_stm32g4xx.c ****   *
 219:Core/Src/system_stm32g4xx.c ****   *         (***) HSE_VALUE is a constant defined in stm32g4xx_hal.h file (default value
 220:Core/Src/system_stm32g4xx.c ****   *              24 MHz), user has to ensure that HSE_VALUE is same as the real
 221:Core/Src/system_stm32g4xx.c ****   *              frequency of the crystal used. Otherwise, this function may
 222:Core/Src/system_stm32g4xx.c ****   *              have wrong result.
 223:Core/Src/system_stm32g4xx.c ****   *
 224:Core/Src/system_stm32g4xx.c ****   *         - The result of this function could be not correct when using fractional
 225:Core/Src/system_stm32g4xx.c ****   *           value for HSE crystal.
 226:Core/Src/system_stm32g4xx.c ****   *
 227:Core/Src/system_stm32g4xx.c ****   * @param  None
 228:Core/Src/system_stm32g4xx.c ****   * @retval None
 229:Core/Src/system_stm32g4xx.c ****   */
 230:Core/Src/system_stm32g4xx.c **** void SystemCoreClockUpdate(void)
ARM GAS  /tmp/ccq5zTqL.s 			page 6


