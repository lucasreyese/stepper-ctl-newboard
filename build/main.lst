  93:Core/Src/main.c ****   /* Give the TMC5160 time to come out of power-on reset */
  94:Core/Src/main.c ****   HAL_Delay(10);
  95:Core/Src/main.c **** 
  96:Core/Src/main.c ****   if (!tmc5160_init())
  97:Core/Src/main.c ****   {
  98:Core/Src/main.c ****     /* No answer on SPI: check driver supply (VS), wiring and CSN */
  99:Core/Src/main.c ****     Error_Handler();
 100:Core/Src/main.c ****   }
 101:Core/Src/main.c **** 
 102:Core/Src/main.c ****   tmc5160_set_driver_enabled(true);
 103:Core/Src/main.c ****   /* USER CODE END 2 */
 104:Core/Src/main.c **** 
 105:Core/Src/main.c ****   /* Infinite loop */
 106:Core/Src/main.c ****   /* USER CODE BEGIN WHILE */
 107:Core/Src/main.c ****   while (1)
 108:Core/Src/main.c ****   {
 109:Core/Src/main.c ****     /* USER CODE END WHILE */
 110:Core/Src/main.c **** 
 111:Core/Src/main.c ****     /* USER CODE BEGIN 3 */
 112:Core/Src/main.c ****     /* Demo: sweep 5 revolutions forward, pause, then back to the start.
 113:Core/Src/main.c ****      * The TMC5160's ramp generator does all the motion; we just set
 114:Core/Src/main.c ****      * targets and poll until each move completes. */
 115:Core/Src/main.c ****     tmc5160_move_to(5 * TMC5160_USTEPS_PER_REV);
 116:Core/Src/main.c ****     while (!tmc5160_position_reached())
 117:Core/Src/main.c ****     {
 118:Core/Src/main.c ****       HAL_Delay(10);
 119:Core/Src/main.c ****     }
 120:Core/Src/main.c ****     HAL_Delay(500);
 121:Core/Src/main.c **** 
 122:Core/Src/main.c ****     tmc5160_move_to(0);
 123:Core/Src/main.c ****     while (!tmc5160_position_reached())
 124:Core/Src/main.c ****     {
 125:Core/Src/main.c ****       HAL_Delay(10);
 126:Core/Src/main.c ****     }
 127:Core/Src/main.c ****     HAL_Delay(500);
 128:Core/Src/main.c ****   }
 129:Core/Src/main.c ****   /* USER CODE END 3 */
 130:Core/Src/main.c **** }
